<% layout('layout/boilerplate') -%>

<body>
  <div class="container">
    <div class="row g-4">
      <% allListings.forEach(listing => { %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
          <a href="/listings/<%= listing.id %>" style="text-decoration:none; color:inherit;"> 
            <div class="card h-100 shadow-sm">
              <img src="<%= listing.image %>" class="card-img-top" alt="<%= listing.title %>">
              <div class="card-body d-flex flex-column">
             
                <h5 class="card-title"><%= listing.title %></h5>
                <p class="card-text mb-1"><strong>Location:</strong> <%= listing.location %>, <%= listing.country %></p>
                <p class="card-text mb-2"><strong>Price:</strong> Rs.<%= listing.price %><strong>/night</strong></p>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  </div>
</body>