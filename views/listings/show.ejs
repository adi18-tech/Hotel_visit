<% layout('layout/boilerplate') -%>

<body>
  <div class="container-fluid my-5">
    <div class="row justify-content-center">
      <div class="col-12">
        <img src="<%= listing.image %>" class="listing-img mb-3 w-100" alt="<%= listing.title %>">

        <h6 class="text-muted mb-3">
          Posted by: <%= listing.owner?.username || 'Unknown' %>
        </h6>

        <h3 class="mb-3"><%= listing.title %></h3>
        <p class="mb-2"><%= listing.description %></p>
        <ul class="list-group list-group-flush mb-3">
          <li class="list-group-item border-0 ps-0"><strong>Price:</strong> ₹<%= listing.price %></li>
          <li class="list-group-item border-0 ps-0"><strong>Location:</strong> <%= listing.location %></li>
          <li class="list-group-item border-0 ps-0"><strong>Country:</strong> <%= listing.country %></li>
        </ul>

        
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning me-2">Edit</a>

          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this listing?')">
            <button type="submit" class="btn btn-danger">Delete</button>
          </form>
   

       
 

        <!-- Review Form -->
        <div class="card mt-5 shadow">
          <div class="card-body">
            <h5 class="card-title mb-3">Leave a Review</h5>
            <form action="/listings/<%= listing._id %>/reviews" method="POST">
              <div class="mb-3">
                <label for="reviewContent" class="form-label">Your Review</label>
                <textarea class="form-control" id="reviewContent" name="review[content]" rows="3" required></textarea>
              </div>

              <div class="mb-3">
                <label for="reviewRating" class="form-label">Rating</label>
                <select class="form-select" id="reviewRating" name="review[rating]" required>
                  <option value="">Choose...</option>
                  <% for (let i = 1; i <= 5; i++) { %>
                    <option value="<%= i %>"><%= i %> Star<%= i > 1 ? 's' : '' %></option>
                  <% } %>
                </select>
              </div>

              <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>
          </div>
        </div>

        <!-- Review List -->
        <div class="mt-5">
          <h4 class="mb-3">What people are saying</h4>

          <% if (listing.reviews.length === 0) { %>
            <p class="text-muted">No reviews yet. Be the first to write one!</p>
          <% } %>

          <% listing.reviews.forEach(review => { %>
            <div class="card mb-3 shadow-sm">
              <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">
                  <i class="bi bi-person-circle"></i>
                  <%= review.author?.username || 'Anonymous' %>
                </h6>
                <p class="card-text mb-1"><%= review.content %></p>
                <div class="text-warning mb-2">
                  <% for (let i = 0; i < review.rating; i++) { %>★<% } %>
                </div>

               
                  <form
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="POST"
                    onsubmit="return confirm('Are you sure you want to delete this review?')"
                  >
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</body>
